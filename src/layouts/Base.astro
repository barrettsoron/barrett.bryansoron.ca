---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const siteTitle = 'Barrett Bryan-Soron';
const defaultDescription = 'Political operator in Vancouver. Building durable infrastructure for eco-socialist movement and party work in Canada. Writing about craft, technology, and the harder work the left has to do now.';
const { title, description = defaultDescription, image = '/og-default.png' } = Astro.props;
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isDev = import.meta.env.DEV;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="preload" href="/fonts/bc-sans/BCSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/bc-sans/BCSans-Bold.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/noto-serif/noto-serif-v33-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="alternate" type="application/rss+xml" title="Barrett Bryan-Soron" href="/rss.xml" />
		<meta name="generator" content={Astro.generator} />
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteTitle} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		{!isDev && <script data-goatcounter="https://barrettbryansoron.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>}
	</head>
	<body>
		<a href="#main" class="skip-link">Skip to content</a>
		<header>
			<a class="site" href="/">Barrett Bryan-Soron</a>
			<nav>
				<a href="/essays" aria-current={pathname.startsWith('/essays') ? 'page' : undefined}>Essays</a>
				<a href="/notes" aria-current={pathname.startsWith('/notes') ? 'page' : undefined}>Notes</a>
				<a href="/now" aria-current={pathname === '/now' ? 'page' : undefined}>Now</a>
				<a href="/about" aria-current={pathname === '/about' ? 'page' : undefined}>About</a>
				{isDev && (
					<a href="/styleguide" class="nav-dev" aria-current={pathname === '/styleguide' ? 'page' : undefined}>Styleguide</a>
				)}
			</nav>
		</header>
		<main id="main">
			<slot />
		</main>
		<footer>
			<nav class="footer-nav" aria-label="Footer">
				<a href="/essays" aria-current={pathname.startsWith('/essays') ? 'page' : undefined}>Essays</a>
				<a href="/notes" aria-current={pathname.startsWith('/notes') ? 'page' : undefined}>Notes</a>
				<a href="/now" aria-current={pathname === '/now' ? 'page' : undefined}>Now</a>
				<a href="/about" aria-current={pathname === '/about' ? 'page' : undefined}>About</a>
				<a href="/newsletter" aria-current={pathname === '/newsletter' ? 'page' : undefined}>Newsletter</a>
				<a href="/rss.xml">RSS</a>
			</nav>
			<p class="footer-contact">
				You can reach me at <a href="mailto:barrett@bryansoron.ca">barrett@bryansoron.ca</a>.
			</p>
			<p class="footer-land">
				Written from the unceded ancestral territories of the xʷməθkʷəy̓əm (Musqueam), Sḵwx̱wú7mesh (Squamish), and səlilwətaʔɬ (Tsleil-Waututh) Nations.
			</p>
			<p class="footer-copyright">&copy; {new Date().getFullYear()} · (Mike) Barrett Bryan-Soron</p>
		</footer>
	</body>
</html>
