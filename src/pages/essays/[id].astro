---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
	const isProd = import.meta.env.PROD;
	const essays = await getCollection('essays', ({ data }) => !isProd || !data.draft);
	return essays.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}

type Props = { entry: CollectionEntry<'essays'> };
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Base title={entry.data.title} description={entry.data.description}>
	<article>
		<h1>{entry.data.title}</h1>
		<p class="post-meta">
			<time datetime={fmt(entry.data.date)}>{fmt(entry.data.date)}</time>
		</p>

		{tocHeadings.length > 1 && (
			<nav class="toc" aria-label="Table of contents">
				<p class="toc-label">Contents</p>
				<ol class="toc-list">
					{tocHeadings.map((h) => (
						<li class={h.depth === 3 ? 'toc-item toc-item--sub' : 'toc-item'}>
							<a href={`#${h.slug}`}>{h.text}</a>
						</li>
					))}
				</ol>
			</nav>
		)}

		<div class="essay-body">
			<Content />
		</div>
	</article>
</Base>
